# ===========================================
# REA AI Hub - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -------------------------------------------
# Database Connection (Neon PostgreSQL)
# -------------------------------------------
# PostgreSQL connection string for Neon serverless database.
# Format: postgresql://<user>:<password>@<host>/<database>
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/rea-ai-hub

# -------------------------------------------
# Authentication
# -------------------------------------------
# Secret key used to sign and verify JWT tokens.
# Must be at least 32 characters long. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here-min-32-chars
